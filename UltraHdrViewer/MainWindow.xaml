<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="UltraHdrViewer.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UltraHdrViewer"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Ultra HDR Viewer">

    <Grid x:Name="ContentRoot" Background="#0B1014">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="340" />
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" Grid.ColumnSpan="2" Background="#121B22" BorderBrush="#243743" BorderThickness="0,0,0,1" Padding="20,16">
            <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,*,Auto" ColumnSpacing="12">
                <Button Content="Open" Click="OnOpenClicked" MinWidth="96" />
                <Button Grid.Column="1" Content="Fit" Click="OnFitClicked" MinWidth="96" />
                <Button Grid.Column="2" Content="100%" Click="OnActualSizeClicked" MinWidth="96" />
                <Button Grid.Column="3" Content="HDR" Click="OnHdrToggleClicked" MinWidth="96" />
                <StackPanel Grid.Column="5" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <TextBlock Text="Backend" Foreground="#95A9B8" />
                    <TextBlock x:Name="BackendStatusText" Text="Vulkan (stub)" FontWeight="SemiBold" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Grid.Column="0" Margin="20,20,10,12" Padding="0" BorderBrush="#30414D" BorderThickness="1" CornerRadius="14" Background="#04070A">
            <Grid>
                <Grid Background="#04070A" />
                <Border BorderBrush="#182229" BorderThickness="1" CornerRadius="14" Margin="12" x:Name="ViewportPlaceholder">
                    <Grid>
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="10">
                            <TextBlock Text="Ultra HDR viewport" FontSize="28" FontWeight="SemiBold" HorizontalAlignment="Center" />
                            <TextBlock Text="A native child HWND is mounted into this region for Vulkan presentation." Foreground="#8DA0AE" TextWrapping="WrapWholeWords" MaxWidth="420" TextAlignment="Center" HorizontalAlignment="Center" />
                            <TextBlock x:Name="ViewportStatusText" Text="Waiting for native viewport initialization..." Foreground="#D2DFE8" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="1" Grid.Column="1" Margin="10,20,20,12" Padding="18" Background="#10171D" CornerRadius="14" BorderBrush="#243743" BorderThickness="1">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="14">
                    <TextBlock Text="Image Inspector" FontSize="24" FontWeight="SemiBold" />
                    <TextBlock Text="This panel will host file metadata, Ultra HDR gain-map state, and display capabilities." Foreground="#9FB3C1" TextWrapping="WrapWholeWords" />

                    <Border Background="#0C1217" CornerRadius="10" Padding="14">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Session" FontWeight="SemiBold" />
                            <TextBlock x:Name="SessionStatusText" Text="No image loaded" Foreground="#C9D6DE" />
                            <TextBlock x:Name="DisplayStatusText" Text="HDR capability detection not wired yet" Foreground="#C9D6DE" TextWrapping="WrapWholeWords" />
                        </StackPanel>
                    </Border>

                    <Border Background="#0C1217" CornerRadius="10" Padding="14">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Planned metadata" FontWeight="SemiBold" />
                            <TextBlock Text="- Pixel dimensions" Foreground="#C9D6DE" />
                            <TextBlock Text="- Color primaries / transfer" Foreground="#C9D6DE" />
                            <TextBlock Text="- Gain map availability" Foreground="#C9D6DE" />
                            <TextBlock Text="- EXIF summary" Foreground="#C9D6DE" />
                            <TextBlock Text="- HDR output path" Foreground="#C9D6DE" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Border Grid.Row="2" Grid.ColumnSpan="2" Background="#10171D" BorderBrush="#243743" BorderThickness="0,1,0,0" Padding="18,10">
            <TextBlock x:Name="StatusBarText" Text="Project scaffold ready: WinUI shell + native viewport host + backend abstraction." Foreground="#D2DFE8" />
        </Border>
    </Grid>
</Window>
